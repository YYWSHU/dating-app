generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum InterestedIn {
  male
  female
  both
}

enum LikeType {
  like
  superlike
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  password           String
  nickname           String
  gender             Gender
  interestedIn       InterestedIn
  birthDate          DateTime
  bio                String?      @db.Text
  tags               String[]
  avatarUrl          String?
  latitude           Float?
  longitude          Float?
  maxDistance        Int          @default(50)
  minAge             Int          @default(18)
  maxAge             Int          @default(60)
  // P0: Email verification
  emailVerified      Boolean      @default(false)
  emailVerifyCode    String?
  emailVerifyExpires DateTime?
  // P0: Rate limiting
  loginAttempts      Int          @default(0)
  lockedUntil        DateTime?
  // Admin
  admin              Boolean      @default(false)
  // P1: Matching
  mbti               String?      // ENUM: INTJ, INFP, etc.
  bigFive            Json?        // {openness, conscientiousness, extraversion, agreeableness, neuroticism}
  // P1: Quota
  dailyLikeCount     Int          @default(0)
  dailyLikeDate      DateTime?
  dailySuperLikeCount Int         @default(0)
  dailySuperLikeDate DateTime?
  // P6: Campus
  campusEmail        Boolean      @default(false)
  // P8: VIP
  isVip              Boolean      @default(false)
  vipExpiresAt       DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  photos            Photo[]
  givenLikes        Like[]        @relation("Liker")
  receivedLikes     Like[]        @relation("Liked")
  sentMessages      Message[]     @relation("Sender")
  matchesAsUser1    Match[]       @relation("User1")
  matchesAsUser2    Match[]       @relation("User2")
  // P6
  reports           Report[]      @relation("Reporter")
  reportedIn        Report[]      @relation("Reported")
  blocks            Block[]       @relation("Blocker")
  blockedBy         Block[]       @relation("Blocked")
  // P7
  userRatings       UserRating[]  @relation("Rater")
  receivedRatings   UserRating[]  @relation("RatedUser")
  // Psychology
  questionnaire     Questionnaire?

  @@index([latitude, longitude])
}

model Photo {
  id         String   @id @default(uuid())
  url        String
  order      Int      @default(0)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // P0: moderation
  isApproved Boolean  @default(true) // auto-approve, set false for manual review
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  likerId   String
  likedId   String
  liker     User     @relation("Liker", fields: [likerId], references: [id], onDelete: Cascade)
  liked     User     @relation("Liked", fields: [likedId], references: [id], onDelete: Cascade)
  type      LikeType @default(like)
  createdAt DateTime @default(now())

  @@unique([likerId, likedId])
  @@index([likedId])
}

// P1: records passes so they can be undone
model PassRecord {
  id        String   @id @default(uuid())
  passerId  String
  passedId  String
  createdAt DateTime @default(now())

  @@unique([passerId, passedId])
  @@index([passerId])
}

model Match {
  id            String    @id @default(uuid())
  user1Id       String
  user2Id       String
  user1         User      @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2         User      @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  lastMessageAt DateTime?
  // P5: memorial date
  matchDate     DateTime  @default(now())
  messages      Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id        String   @id @default(uuid())
  content   String   @db.Text
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  // P2: message type & recall
  type      String   @default("text") // text, image, emoji, system
  imageUrl  String?
  isRecalled Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
}

// P0: Refresh token blacklist
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// P6: Report system
model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId String
  reported   User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
  reason     String   // inappropriate, fake, spam, harassment, other
  detail     String?  @db.Text
  status     String   @default("pending") // pending, reviewed, resolved
  createdAt  DateTime @default(now())
}

// P6: Block system
model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

// P7: User ratings
model UserRating {
  id         String   @id @default(uuid())
  raterId    String
  rater      User     @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUserId String
  ratedUser  User     @relation("RatedUser", fields: [ratedUserId], references: [id], onDelete: Cascade)
  score      Int      // 1-5
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@unique([raterId, ratedUserId])
}

// Psychology questionnaire
model Questionnaire {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Attachment style (Bowlby/Ainsworth) - scores for 4 dimensions
  attachmentSecure   Float @default(0) // 0-1
  attachmentAnxious  Float @default(0)
  attachmentAvoidant Float @default(0)
  attachmentFearful  Float @default(0)
  attachmentLabel    String? // dominant: secure/anxious/avoidant/fearful

  // Love languages (Gary Chapman) - scores 0-1
  loveWordsOfAffirmation Float @default(0)
  loveActsOfService       Float @default(0)
  loveReceivingGifts      Float @default(0)
  loveQualityTime         Float @default(0)
  lovePhysicalTouch       Float @default(0)
  loveLanguageLabel       String? // dominant

  // Conflict style (Thomas-Kilmann)
  conflictAvoiding    Float @default(0)
  conflictCompeting   Float @default(0)
  conflictCompromising Float @default(0)
  conflictAccommodating Float @default(0)
  conflictCollaborating Float @default(0)
  conflictLabel       String? // dominant

  // Communication style
  communicationDirect   Float @default(0.5)
  communicationEmotional Float @default(0.5)
  communicationLabel    String?

  // Social style
  socialInitiative  Float @default(0.5) // starts conversations
  socialGroupSize   Float @default(0.5) // prefers small(0) vs large(1) groups
  socialPlanning    Float @default(0.5) // spontaneous(0) vs planned(1)

  // Relationship values (ranked)
  valueAppearance    Float @default(0) // 0-1 normalized
  valuePersonality   Float @default(0)
  valueCareer        Float @default(0)
  valueFamily        Float @default(0)
  valueSharedInterests Float @default(0)
  valueEmotional     Float @default(0)
  valueFinancial     Float @default(0)
  valueLifestyle     Float @default(0)

  // Life stage & goals
  lifeGoal           String? // casual/finding_partner/marriage/family/exploring
  lifePriority       String? // career_first/love_first/balanced/free_spirit

  completedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// P7: AI conversation starters cache
model ConversationStarter {
  id        String   @id @default(uuid())
  matchId   String   @unique
  starters  String[] // array of 3 suggested openers
  createdAt DateTime @default(now())
}
